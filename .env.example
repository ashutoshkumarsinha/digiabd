# API
NODE_ENV=development
PORT=3000
API_VERSION=v1
JWT_SECRET=change-me-in-production-use-long-random-string

# PostgreSQL + PostGIS
DATABASE_URL=postgresql://digiabd:digiabd@localhost:5432/digiabd

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=digiabd
S3_SECRET_KEY=digiabd-secret
S3_BUCKET=digiabd-files
S3_REGION=ap-south-1
S3_USE_SSL=false

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# Kafka / Redpanda
KAFKA_BROKERS=localhost:19092
KAFKA_ENABLED=false

# Auth: dev | oidc | hybrid
AUTH_MODE=hybrid
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# OpenTelemetry / SigNoz
OTEL_ENABLED=true
OTEL_SERVICE_NAME=digiabd-api
OTEL_SERVICE_VERSION=0.4.0
# For local SigNoz standalone this should be http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Comma-separated key=value entries (optional)
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL_MS=10000
